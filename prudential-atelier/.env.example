# DATABASE
DATABASE_URL=
DIRECT_URL=

# AUTH — use the same public origin for both in production (e.g. https://prudentgabriel.com)
# Auth.js v5 prefers AUTH_SECRET; NEXTAUTH_SECRET still works if set in auth config.
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# PAYMENTS
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://api.monnify.com

# EMAIL
RESEND_API_KEY=

# CURRENCY
OPEN_EXCHANGE_RATES_APP_ID=

# SETTINGS (encrypt payment keys at rest in DB — use a long random secret in production)
SETTINGS_ENCRYPTION_KEY=

# APP — seed creates admin@prudentgabriel.com / Admin@PA2024! unless you override in seed
ADMIN_EMAIL=admin@prudentgabriel.com
ADMIN_PASSWORD=
CRON_SECRET=
